            2: [3, 0],  # 已接单 -> 回收中/取消
            3: [4],     # 回收中 -> 完成
        }
        
        if new_status not in allowed_transitions.get(order.status, []):
            raise BusinessException("非法状态转换")
        
        order.status = new_status
        
        # 记录状态变更日志...
        
        db.session.commit()
 
 
