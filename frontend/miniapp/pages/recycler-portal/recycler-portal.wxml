<!-- 回收员工作台 -->

<!-- ═══ 检测中 ═══ -->
<view class="gate" hidden="{{recyclerInfo || checked}}">
  <view class="gate-inner">
    <text class="gate-emoji">🚚</text>
    <text class="gate-title">正在验证身份...</text>
  </view>
</view>

<!-- ═══ 无法进入（未登录 / 非回收员） ═══ -->
<view class="gate" hidden="{{recyclerInfo || !checked}}">
  <view class="gate-inner">
    <text class="gate-emoji">🚫</text>
    <text class="gate-title">{{gateMsg}}</text>
    <text class="gate-sub">{{gateSub}}</text>
    <button class="btn-go" bindtap="handleGateAction">{{gateBtnText}}</button>
  </view>
</view>

<!-- ═══ 已登录 ═══ -->
<view class="portal-page" hidden="{{!recyclerInfo}}">

  <!-- 头部信息 -->
  <view class="header-card">
    <view class="header-top">
      <view>
        <text class="r-name">{{recyclerInfo.name}}</text>
        <text class="r-area">负责区域：{{recyclerInfo.area}}</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{recyclerInfo.order_count}}</text>
        <text class="stat-label">累计订单</text>
      </view>
    </view>
    <view class="header-bottom">
      <text class="r-phone">📱 {{recyclerInfo.phone}}</text>
      <view class="rating-row">
        <text class="rating-label">评分</text>
        <text class="rating-val">⭐ {{recyclerInfo.rating}}</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab {{activeTab === 'ongoing' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="ongoing">进行中</view>
    <view class="tab {{activeTab === 'done' ? 'tab-active' : ''}}"    bindtap="switchTab" data-tab="done">已完成</view>
  </view>

  <!-- 订单列表 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{orders.length === 0}}" class="empty-wrap">
    <text class="empty-icon">📦</text>
    <text class="empty-text">{{activeTab === 'ongoing' ? '暂无进行中的订单' : '暂无已完成订单'}}</text>
  </view>

  <view wx:else class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <!-- 订单头 -->
      <view class="order-head">
        <text class="order-no">{{item.order_no}}</text>
        <view class="status-tag status-{{item.status}}">{{item.status_label}}</view>
      </view>
      <!-- 联系信息 -->
      <view class="info-row">
        <text class="info-icon">👤</text>
        <text class="info-text">{{item.addr_contact}}  {{item.addr_phone}}</text>
        <button class="call-btn" open-type="makePhoneCall" phone-number="{{item.addr_phone}}">拨号</button>
      </view>
      <view class="info-row">
        <text class="info-icon">📍</text>
        <text class="info-text">{{item.addr_full}}</text>
      </view>
      <view class="info-row">
        <text class="info-icon">⏰</text>
        <text class="info-text">{{item.scheduled_time}}</text>
      </view>
      <view class="info-row" wx:if="{{item.notes}}">
        <text class="info-icon">📝</text>
        <text class="info-text" style="color:#888">{{item.notes}}</text>
      </view>
      <!-- 品类 -->
      <view class="cat-row">
        <view class="cat-chip" wx:for="{{item.categories}}" wx:key="category" wx:for-item="cat">
          {{cat.category}} ×{{cat.qty}}
        </view>
        <text class="weight-hint">预估{{item.estimated_weight ? item.estimated_weight*10+'kg' : '待确认'}}</text>
      </view>
      <!-- 凭证图片 -->
      <view class="proof-section" wx:if="{{item.proof_images.length > 0}}">
        <text class="proof-title">已上传凭证（{{item.proof_images.length}}张）</text>
        <view class="proof-imgs">
          <image
            class="proof-img"
            wx:for="{{item.proof_images}}" wx:key="*this" wx:for-item="imgUrl"
            src="{{apiBase + imgUrl}}"
            mode="aspectFill"
            bindtap="previewImg"
            data-src="{{apiBase + imgUrl}}"
            data-list="{{item.proof_images}}"
            data-base="{{apiBase}}"
          />
        </view>
      </view>
      <!-- 操作区：根据状态展示不同操作 -->
      <view wx:if="{{activeTab === 'ongoing'}}">
        <!-- 待接单：提示等待或自行接单 -->
        <view wx:if="{{item.status === 0}}" class="tip-bar tip-pending">
          <text>📋 已指派给您，请确认接单</text>
          <button class="btn-sm-green" bindtap="acceptOrder" data-orderid="{{item.id}}" data-idx="{{index}}">确认接单</button>
        </view>
        <!-- 已接单/回收中：上传凭证 + 标记完成 -->
        <view wx:elif="{{item.status === 1 || item.status === 2}}">
          <!-- 步骤提示 -->
          <view class="step-hint">
            <view class="step {{item.proof_images.length > 0 ? 'step-done' : 'step-active'}}">
              <text class="step-num">{{item.proof_images.length > 0 ? '✓' : '1'}}</text>
              <text class="step-text">上传凭证</text>
            </view>
            <view class="step-line"></view>
            <view class="step {{item.proof_images.length > 0 ? 'step-active' : 'step-todo'}}">
              <text class="step-num">2</text>
              <text class="step-text">标记完成</text>
            </view>
          </view>
          <view class="action-row">
            <button class="btn-upload" bindtap="chooseProofImg" data-orderid="{{item.id}}" data-idx="{{index}}">
              📷 {{item.proof_images.length > 0 ? '补传凭证' : '上传凭证'}}
            </button>
            <button
              class="btn-complete"
              bindtap="openComplete"
              data-orderid="{{item.id}}"
              data-idx="{{index}}"
              disabled="{{item.proof_images.length === 0}}"
            >✅ 标记完成</button>
          </view>
          <text wx:if="{{item.proof_images.length === 0}}" class="step-tip-text">请先上传取件凭证图片</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出 -->
  <view style="padding:20rpx 24rpx 80rpx">
    <button class="logout-btn" bindtap="handleLogout">退出工作台</button>
  </view>
</view>

<!-- 填报重量 & 标记完成弹窗 -->
<view class="modal-mask" wx:if="{{showComplete}}" bindtap="closeComplete">
  <view class="modal-box" catchtap>
    <text class="modal-title">填写实际重量并完成</text>
    <text class="modal-sub">提交后订单立即完成，用户积分自动到账</text>
    <view class="weight-input-wrap">
      <input class="weight-input" type="digit" placeholder="实际重量（kg）" value="{{actualWeight}}" bindinput="onWeightInput" focus="{{showComplete}}" />
      <text class="weight-unit">kg</text>
    </view>
    <view class="modal-btns">
      <button class="modal-btn modal-cancel" bindtap="closeComplete">取消</button>
      <button class="modal-btn modal-confirm" bindtap="submitComplete" disabled="{{completing}}">
        {{completing ? '提交中...' : '确认完成'}}
      </button>
    </view>
  </view>
</view>

<!-- 完成结果弹窗 -->
<view class="modal-mask" wx:if="{{showResult}}">
  <view class="result-box">
    <text class="result-icon">🎉</text>
    <text class="result-title">订单已完成！</text>
    <view class="result-row">
      <text class="result-label">实际重量</text>
      <text class="result-val">{{resultData.actual_weight}} kg</text>
    </view>
    <view class="result-row">
      <text class="result-label">结算金额</text>
      <text class="result-val result-money">¥ {{resultData.final_amount}}</text>
    </view>
    <view class="result-row">
      <text class="result-label">用户获得积分</text>
      <text class="result-val" style="color:#f59e0b">+{{resultData.points_earned}} 分</text>
    </view>
    <button class="modal-btn modal-confirm" style="margin-top:32rpx;width:100%" bindtap="closeResult">知道了</button>
  </view>
</view>
