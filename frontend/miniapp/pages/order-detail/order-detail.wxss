.status-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 36rpx 30rpx;
  margin-top: 20rpx;
}

.status-icon  { font-size: 80rpx; }

.status-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-desc {
  display: block;
  font-size: 24rpx;
  color: #888;
}

.info-card {
  padding: 28rpx 30rpx;
  margin-bottom: 0;
}

.info-card + .info-card { margin-top: 0; }

.info-title {
  display: block;
  font-size: 24rpx;
  color: #aaa;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child { border-bottom: none; }

.info-key {
  font-size: 26rpx;
  color: #888;
  width: 140rpx;
  flex-shrink: 0;
}

.info-val {
  flex: 1;
  font-size: 26rpx;
  color: #1a1a1a;
  text-align: right;
}

.cat-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.cat-tag-big {
  background: #e8f5ee;
  color: #4caf7d;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.notes-text {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.cancel-btn {
  background: #fff !important;
  color: #ee0a24 !important;
  border: 1rpx solid #ee0a24 !important;
  border-radius: 50rpx;
  font-size: 30rpx;
  height: 90rpx;
  width: 400rpx;
}
