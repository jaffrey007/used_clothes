<!-- 个人中心 -->

<!-- ══ 未登录状态 ══ -->
<view class="login-gate" wx:if="{{!isLoggedIn}}">
  <view class="login-gate-inner">
    <text class="gate-emoji">♻️</text>
    <text class="gate-title">慢夏回收</text>
    <text class="gate-sub">登录后可查看积分、管理订单、编辑个人资料</text>
    <button
      class="btn-primary wx-login-btn"
      bindtap="handleLogin"
      loading="{{logging}}"
    >
      微信一键登录
    </button>
    <text class="gate-hint">登录即同意《用户服务协议》与《隐私政策》</text>
  </view>
</view>

<!-- ══ 已登录状态 ══ -->
<view class="page profile-page" wx:else>

  <!-- 用户头部 -->
  <view class="profile-header">
    <image
      class="avatar"
      src="{{userInfo.avatar_url || '/images/default-avatar.png'}}"
      mode="aspectFill"
      bindtap="goEdit"
    />
    <view class="user-info">
      <text class="user-name">{{userInfo.nickname || '用户'}}</text>
      <text class="user-phone">{{userInfo.phone || '未绑定手机'}}</text>
    </view>
    <view class="points-badge">
      <text class="pts-val">{{userInfo.points || 0}}</text>
      <text class="pts-label">积分</text>
    </view>
  </view>

  <!-- 订单快捷入口 -->
  <view class="card shortcuts">
    <view class="shortcut" wx:for="{{shortcuts}}" wx:key="label" bindtap="goOrders" data-status="{{item.status}}">
      <text class="sc-icon">{{item.icon}}</text>
      <text class="sc-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 环保数据 -->
  <view class="card eco-card">
    <view class="eco-item" bindtap="goPoints">
      <text class="eco-val text-primary">{{recycleCount}}次</text>
      <text class="eco-label">参与回收次数</text>
    </view>
    <view class="eco-divider"></view>
    <view class="eco-item" bindtap="showCarbonInfo">
      <text class="eco-val" style="color:#1989fa">{{carbonKg}}kg</text>
      <text class="eco-label">减碳量(kg)</text>
    </view>
    <view class="eco-divider"></view>
    <view class="eco-item" bindtap="showCarbonInfo">
      <text class="eco-val" style="color:#ff976a">查看</text>
      <text class="eco-label">减碳计算规则</text>
    </view>
  </view>

  <!-- 邀请卡 -->
  <view class="card invite-card" bindtap="showInvite">
    <view class="invite-text">
      <text class="invite-title">开启副业 分享赚钱！</text>
      <text class="invite-sub">体验每天被动收入，躺着收钱！</text>
    </view>
    <view class="invite-btn">去邀请 ›</view>
  </view>

  <!-- 服务菜单 -->
  <view class="card service-grid">
    <view class="svc-item" wx:for="{{services}}" wx:key="label" bindtap="handleService" data-action="{{item.action}}">
      <text class="svc-icon">{{item.icon}}</text>
      <text class="svc-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view style="padding:20rpx 24rpx 60rpx">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

</view>

<!-- 减碳规则弹窗 -->
<view class="modal-mask" wx:if="{{showCarbon}}" bindtap="hideCarbon">
  <view class="modal-box" catchtap>
    <text class="modal-title">减碳计算规则</text>
    <text style="font-size:28rpx;color:#555;line-height:1.8">
      每回收1kg衣物，约可减少3.6kg碳排放。\n数据参考：联合国环境署相关报告。\n减碳量 = 回收重量(kg) × 3.6
    </text>
    <button class="btn-primary" style="margin-top:30rpx;height:84rpx" bindtap="hideCarbon">知道了</button>
  </view>
</view>

<!-- 邀请弹窗 -->
<view class="modal-mask" wx:if="{{showInviteModal}}" bindtap="hideInvite">
  <view class="modal-box" catchtap style="text-align:center">
    <text style="font-size:80rpx">🎁</text>
    <text class="modal-title" style="margin-top:16rpx">邀请好友，共同赚钱</text>
    <text style="font-size:26rpx;color:#888;display:block;margin-bottom:30rpx">每成功邀请1位好友，可获得20积分奖励</text>
    <button class="btn-primary" style="height:84rpx" bindtap="copyInviteLink">复制邀请链接</button>
  </view>
</view>
