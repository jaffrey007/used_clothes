.edit-page { padding-bottom: 60rpx; }

/* 头像区 */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 60rpx 0 40rpx;
}

/* button 必须重置样式才能当容器用 */
.avatar-btn {
  width: 160rpx !important;
  height: 160rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  border-radius: 80rpx !important;
  border: none !important;
  background: transparent !important;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.avatar-btn::after { border: none !important; }

.edit-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  display: block;
}

/* 遮罩层 */
.avatar-mask {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60rpx;
  background: rgba(0,0,0,0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.avatar-cam { font-size: 22rpx; line-height: 1; }
.avatar-tip { font-size: 16rpx; color: rgba(255,255,255,0.9); line-height: 1; }

/* 表单区 */
.field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 0;
  min-height: 88rpx;
}

.field-label {
  font-size: 28rpx;
  color: #555;
  width: 140rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  text-align: right;
}

.divider { height: 1rpx; background: #f0f0f0; }
