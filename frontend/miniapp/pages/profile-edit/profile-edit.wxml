<view class="page edit-page">

  <!-- 头像区 -->
  <view class="avatar-section">
    <button
      class="avatar-btn"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
    >
      <image
        class="edit-avatar"
        src="{{avatarSrc || '/images/default-avatar.png'}}"
        mode="aspectFill"
      />
      <view class="avatar-mask">
        <text class="avatar-cam">📷</text>
        <text class="avatar-tip">点击更换头像</text>
      </view>
    </button>
  </view>

  <view class="card" style="padding:0 30rpx">

    <!-- 昵称：type="nickname" 会自动弹出微信昵称建议 -->
    <view class="field-row">
      <text class="field-label">昵称</text>
      <input
        class="field-input"
        type="nickname"
        placeholder="点击填写微信昵称"
        maxlength="20"
        value="{{nickname}}"
        bindinput="onInput"
        data-key="nickname"
        bindblur="onNicknameBlur"
      />
    </view>
    <view class="divider"></view>

    <!-- 手机号：手动输入 -->
    <view class="field-row">
      <text class="field-label">手机号</text>
      <input
        class="field-input"
        type="number"
        placeholder="请输入手机号"
        maxlength="11"
        value="{{phone}}"
        bindinput="onInput"
        data-key="phone"
      />
    </view>

  </view>

  <view style="padding:40rpx 30rpx 0">
    <button class="btn-primary" style="height:96rpx;font-size:32rpx" bindtap="handleSave" disabled="{{saving}}">
      {{saving ? '保存中...' : '保存'}}
    </button>
  </view>

</view>
