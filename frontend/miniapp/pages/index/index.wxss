.banner {
  height: 340rpx;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  height: 340rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}

.banner-content { flex: 1; }

.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.banner-sub {
  display: block;
  font-size: 26rpx;
  color: #555;
}

.banner-emoji {
  font-size: 120rpx;
  line-height: 1;
}

/* Stats bar */
.stats-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  min-height: 80rpx;
}

.stats-text { font-size: 28rpx; color: #555; line-height: 1.4; }
.stats-num  { font-size: 36rpx; font-weight: 700; }

/* Ticker */
.ticker-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 30rpx;
  gap: 12rpx;
}

.ticker-icon { font-size: 32rpx; }

.ticker-scroll { flex: 1; white-space: nowrap; }

.ticker-text {
  font-size: 26rpx;
  color: #555;
  white-space: nowrap;
  animation: scroll-left 20s linear infinite;
}

@keyframes scroll-left {
  from { transform: translateX(100%); }
  to   { transform: translateX(-100%); }
}

/* Steps */
.steps {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 24rpx 30rpx;
  gap: 8rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  position: relative;
  flex: 1;
}

.step-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #e8f5ee;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-icon  { font-size: 44rpx; }
.step-label { font-size: 22rpx; color: #555; text-align: center; }

.step-arrow {
  position: absolute;
  right: -14rpx;
  top: 26rpx;
  font-size: 36rpx;
  color: #4caf7d;
  font-weight: 700;
}

/* FAQ */
.faq-card { padding: 28rpx 30rpx; }

.faq-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.faq-more { font-size: 26rpx; }

.faq-list { display: flex; flex-direction: column; gap: 16rpx; }

.faq-item {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  font-size: 28rpx;
  color: #555;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.faq-num { font-weight: 600; }

/* 弹窗内关闭按钮 */
.modal-box .btn-primary {
  margin-top: 30rpx;
}

/* Modal */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.modal-box {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx 60rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 30rpx;
}

.modal-faq-list { display: flex; flex-direction: column; gap: 24rpx; margin-bottom: 40rpx; }

.modal-faq-q {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.modal-faq-a {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
