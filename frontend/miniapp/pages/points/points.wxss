.pts-hero {
  background: linear-gradient(135deg, #4caf7d, #2e7d52);
  padding: 60rpx 30rpx 50rpx;
  text-align: center;
}

.pts-big {
  display: block;
  font-size: 112rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  margin-bottom: 10rpx;
}

.pts-label {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 6rpx;
}

.pts-earned {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
}

.record-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-left { flex: 1; }

.record-note {
  display: block;
  font-size: 28rpx;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}

.record-date { display: block; font-size: 22rpx; color: #aaa; }

.record-amount { font-size: 32rpx; font-weight: 700; }
.amount-earn   { color: #4caf7d; }
.amount-spend  { color: #ee0a24; }
