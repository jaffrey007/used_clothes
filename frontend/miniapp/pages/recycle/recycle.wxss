.price-card { padding: 36rpx 30rpx 28rpx; }

.price-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.price-row { display: flex; flex-direction: row; align-items: baseline; gap: 8rpx; }

.price-num { font-size: 72rpx; font-weight: 800; color: #4caf7d; }
.price-unit { font-size: 30rpx; color: #888; }

/* Categories */
.cat-label {
  display: block;
  padding: 28rpx 30rpx 12rpx;
  font-size: 26rpx;
  color: #555;
}

.cat-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 12rpx 20rpx 28rpx;
}

.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  background: #fafafa;
}

.cat-active {
  border-color: #4caf7d;
  background: #e8f5ee;
}

.cat-emoji { font-size: 64rpx; line-height: 1; }
.cat-name  { font-size: 22rpx; color: #555; }

/* Form rows */
.form-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 30rpx;
  min-height: 100rpx;
  box-sizing: border-box;
  background: transparent;
}

/* picker 默认有额外样式，需要重置 */
picker { display: block; }

.form-label {
  font-size: 28rpx;
  color: #1a1a1a;
  width: 140rpx;
  flex-shrink: 0;
}

.form-right {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.form-val         { font-size: 26rpx; color: #1a1a1a; flex: 1; text-align: right; }
.form-placeholder { font-size: 26rpx; color: #bbb;    flex: 1; text-align: right; }
.form-arrow       { font-size: 32rpx; color: #bbb; }
.form-divider     { height: 1rpx; background: #f0f0f0; margin: 0 30rpx; }

/* Weight */
.weight-chips {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 0 24rpx 30rpx;
}

.weight-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ebedf0;
  border-radius: 16rpx;
  padding: 18rpx 8rpx;
  background: #fafafa;
  min-height: 100rpx;
}

.chip-active {
  border-color: #4caf7d;
  background: #e8f5ee;
}

.chip-main {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}

.chip-sub {
  display: block;
  font-size: 20rpx;
  color: #888;
  text-align: center;
}

/* Notes */
.notes-card { padding: 0 30rpx 30rpx; }

.quick-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 0 20rpx;
}

.qtag {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  height: 60rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #555;
  background: #f5f5f5;
  border: 2rpx solid #eee;
}

.qtag-active {
  color: #4caf7d;
  background: #e8f5ee;
  border-color: #4caf7d;
}

.note-input {
  width: 100%;
  border: 1rpx solid #ebedf0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #555;
  background: #fafafa;
  box-sizing: border-box;
}

/* Submit bar — 确保在最上层 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(245,245,245,0.97);
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
  z-index: 99;
}

.submit-btn { width: 100%; height: 96rpx; font-size: 32rpx; }

/* ─── 地址选择弹窗 ─── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  z-index: 200;
}

.modal-box {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 30rpx calc(40rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-hd {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0 24rpx;
  flex-shrink: 0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.modal-close {
  font-size: 36rpx;
  color: #bbb;
  padding: 10rpx;
}

.addr-scroll {
  flex: 1;
  max-height: 50vh;
}

.addr-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.addr-selected { background: #f0fbf5; border-radius: 12rpx; padding-left: 12rpx; }

.addr-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.addr-name  { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.addr-phone { font-size: 26rpx; color: #888; }
.addr-detail{ display: block; font-size: 24rpx; color: #666; }

.addr-check {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #4caf7d;
  font-size: 36rpx;
  font-weight: 700;
}
