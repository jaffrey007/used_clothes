.tabs {
  display: flex;
  flex-direction: row;
  background: #fff;
  padding: 0 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  font-size: 26rpx;
  color: #888;
  position: relative;
}

.tab-active {
  color: #4caf7d;
  font-weight: 600;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #4caf7d;
  border-radius: 2rpx;
}

.order-list { padding: 12rpx 0; }

.order-card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
}

.order-hd {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.order-no { font-size: 24rpx; color: #aaa; }

.order-cats {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.cat-tag {
  background: #f5f5f5;
  color: #555;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.order-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.meta-row { font-size: 24rpx; color: #666; }

.order-ft {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.order-date { font-size: 22rpx; color: #bbb; }

.order-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid;
}

.action-cancel {
  color: #ee0a24;
  border-color: #ee0a24;
}

.action-detail {
  color: #4caf7d;
  border-color: #4caf7d;
}

.loading-tip {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  padding: 30rpx 0;
}

.btn-sm {
  background: #4caf7d !important;
  color: #fff !important;
  border: none !important;
  border-radius: 40rpx;
  font-size: 26rpx;
  height: 72rpx;
  min-width: 200rpx;
  padding: 0 40rpx;
}
